# Build stage
FROM golang:1.25.1-alpine AS builder

WORKDIR /build

COPY go.mod go.sum ./
RUN go mod download

COPY cmd/      ./cmd/
COPY internal/ ./internal/

RUN CGO_ENABLED=0 GOOS=linux go build -o /judge-worker ./cmd/judge-worker

# Runtime stage — needs docker-cli to spawn sandbox containers
FROM alpine:3.19

RUN apk add --no-cache ca-certificates tzdata docker-cli

COPY --from=builder /judge-worker /judge-worker

ENTRYPOINT ["/judge-worker"]
