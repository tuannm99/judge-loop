# Build stage — CGO required for go-sqlite3
FROM golang:1.26.0-alpine AS builder

RUN apk add --no-cache gcc musl-dev

WORKDIR /build

COPY go.mod go.sum ./
RUN go mod download

COPY cmd/      ./cmd/
COPY internal/ ./internal/

RUN CGO_ENABLED=1 GOOS=linux go build -o /local-agent ./cmd/local-agent

# Runtime stage
FROM alpine:3.19

RUN apk add --no-cache ca-certificates tzdata

COPY --from=builder /local-agent /local-agent

EXPOSE 7070

ENTRYPOINT ["/local-agent"]
