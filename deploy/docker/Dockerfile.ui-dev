FROM node:20-alpine

WORKDIR /workspace/ui

ENV CHOKIDAR_USEPOLLING=true

COPY deploy/docker/ui-dev-entrypoint.sh /usr/local/bin/ui-dev-entrypoint.sh
RUN chmod +x /usr/local/bin/ui-dev-entrypoint.sh

COPY ui/package*.json ./
RUN npm ci && cp package-lock.json node_modules/.package-lock.json

EXPOSE 3000

ENTRYPOINT ["/usr/local/bin/ui-dev-entrypoint.sh"]
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0", "--port", "3000", "--strictPort"]
